---
import Layout from '../layouts/Layout.astro';
import Counter from '../components/Counter.jsx';

// ハイブリッドモードにおいて、このページをSSR（オンデマンドサーバーサイドレンダリング）として扱う設定
export const prerender = false;

// 1. リクエストごとのサーバー時刻を取得
const serverTime = new Date().toLocaleTimeString('ja-JP', {
  hour: '2-digit',
  minute: '2-digit',
  second: '2-digit',
  hour12: false
});

// 2. 外部APIから動的データをサーバーサイドでフェッチ
let user = null;
let error = null;

try {
  const res = await fetch('https://randomuser.me/api/');
  if (!res.ok) {
    throw new Error('ユーザーデータの取得に失敗しました');
  }
  const data = await res.json();
  user = data.results[0];
} catch (e) {
  error = e instanceof Error ? e.message : 'エラーが発生しました';
}
---

<Layout>
  <main class="min-h-screen bg-slate-950 text-slate-100 flex flex-col items-center justify-center p-6 font-sans">
    
    <div class="max-w-md w-full bg-slate-900 border border-slate-850 rounded-xl p-8">
      
      <!-- SSRインジケーター -->
      <div class="flex justify-between items-center mb-6 text-xs">
        <span class="px-2 py-0.5 bg-slate-800 text-slate-300 border border-slate-700 rounded">
          SSR (オンデマンド)
        </span>
        <span class="text-slate-500">
          時刻: <span class="font-mono text-slate-400">{serverTime}</span>
        </span>
      </div>

      <!-- タイトル -->
      <h1 class="text-xl font-bold text-slate-100 mb-2">
        SSR リアルタイムフェッチ
      </h1>
      <p class="text-slate-400 text-xs mb-6 leading-relaxed">
        このページはリクエストされるたびにサーバー上でJavaScriptが動き、外部API（RandomUser API）からデータをフェッチしてHTMLを生成しています。
      </p>

      <!-- APIデータ表示部分 -->
      {error ? (
        <div class="p-4 bg-red-950/20 border border-red-900/30 rounded text-red-400 text-xs">
          ⚠️ エラー: {error}
        </div>
      ) : user ? (
        <div class="space-y-6">
          <!-- ユーザーアバターと基本情報 -->
          <div class="flex items-center gap-4 p-4 bg-slate-950 rounded-xl border border-slate-850">
            <div class="relative w-14 h-14 rounded-full border border-slate-800 overflow-hidden">
              <img 
                src={user.picture.large} 
                alt={user.name.first} 
                class="w-full h-full  object-cover"
              />
              <div class="absolute inset-0 bg-black/30"></div>
            </div>
            
            <div>
              <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider">Generated User</div>
              <h2 class="text-base font-bold text-slate-200">
                {user.name.title} {user.name.first} {user.name.last}
              </h2>
              <p class="text-xs text-slate-400 font-mono mt-0.5">{user.email}</p>
            </div>
          </div>

          <!-- 詳細データ -->
          <div class="grid grid-cols-2 gap-4 text-xs">
            <div class="p-3 bg-slate-950 rounded border border-slate-850">
              <span class="text-slate-500 block mb-1">🌍 国・地域</span>
              <span class="font-medium text-slate-300">{user.location.country}</span>
            </div>
            <div class="p-3 bg-slate-950 rounded border border-slate-850">
              <span class="text-slate-500 block mb-1">🎂 年齢</span>
              <span class="font-medium text-slate-300">{user.dob.age} 歳</span>
            </div>
          </div>
        </div>
      ) : (
        <div class="text-center py-6 text-slate-500 text-xs">
          読み込み中...
        </div>
      )}

      <!-- インタラクティブな React の島 (Island) -->
      <div class="mt-8 pt-6 border-t border-slate-850">
        <Counter client:load />
      </div>

      <!-- 操作エリア -->
      <div class="mt-6 pt-6 border-t border-slate-850 flex flex-col gap-3">
        <button 
          onclick="window.location.reload()" 
          class="w-full py-2.5 bg-slate-800 hover:bg-slate-750 text-slate-200 font-medium rounded-xl border border-slate-700 transition cursor-pointer text-center text-sm"
        >
          ページを再読み込みする
        </button>
        
        <a href="/" class="text-center text-xs text-slate-500 hover:text-slate-300 transition hover:underline mt-2">
          ← ダッシュボードに戻る
        </a>
      </div>

    </div>
  </main>
</Layout>
