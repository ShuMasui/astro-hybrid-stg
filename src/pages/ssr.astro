---
import Layout from '../layouts/Layout.astro';
import Counter from '../components/Counter.jsx';

// ハイブリッドモードにおいて、このページをSSR（オンデマンドサーバーサイドレンダリング）として扱う設定
export const prerender = false;

// 1. リクエストごとのサーバー時刻を取得
const serverTime = new Date().toLocaleTimeString('ja-JP', {
  hour: '2-digit',
  minute: '2-digit',
  second: '2-digit',
  hour12: false
});

// 2. 外部APIから動的データをサーバーサイドでフェッチ
let user = null;
let error = null;

try {
  const res = await fetch('https://randomuser.me/api/');
  if (!res.ok) {
    throw new Error('ユーザーデータの取得に失敗しました');
  }
  const data = await res.json();
  user = data.results[0];
} catch (e) {
  error = e instanceof Error ? e.message : 'エラーが発生しました';
}
---

<Layout>
  <main class="min-h-screen bg-slate-950 text-slate-100 flex flex-col items-center justify-center p-6 relative overflow-hidden font-sans">
    <!-- 背景グラデーション効果 -->
    <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/3 left-1/4 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-md w-full bg-slate-900 border border-slate-800 rounded-3xl p-8 shadow-2xl z-10 relative">
      
      <!-- SSRインジケーター -->
      <div class="flex justify-between items-center mb-6">
        <span class="px-3 py-1 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded-full text-xs font-bold tracking-wide uppercase">
          SSR (オンデマンド)
        </span>
        <span class="text-xs text-slate-500">
          Reloaded at: <span class="font-mono text-slate-400">{serverTime}</span>
        </span>
      </div>

      <!-- タイトル -->
      <h1 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 mb-2">
        SSR リアルタイムフェッチ
      </h1>
      <p class="text-slate-400 text-xs mb-6 leading-relaxed">
        このページはリクエストされるたびにサーバー上でJavaScriptが動き、外部API（RandomUser API）から新しいデータをフェッチしてHTMLを生成しています。
      </p>

      <!-- APIデータ表示部分 -->
      {error ? (
        <div class="p-4 bg-red-950/30 border border-red-800/30 rounded-2xl text-red-400 text-sm">
          ⚠️ エラーが発生しました: {error}
        </div>
      ) : user ? (
        <div class="space-y-6">
          <!-- ユーザーアバターと基本情報 -->
          <div class="flex items-center gap-4 p-4 bg-slate-800/40 rounded-2xl border border-slate-800">
            <img 
              src={user.picture.large} 
              alt={user.name.first} 
              class="w-16 h-16 rounded-full border-2 border-indigo-500/30 object-cover"
            />
            <div>
              <div class="text-xs text-indigo-400 font-semibold uppercase tracking-wider">Generated User</div>
              <h2 class="text-lg font-bold text-slate-100">
                {user.name.title} {user.name.first} {user.name.last}
              </h2>
              <p class="text-xs text-slate-400 font-mono mt-0.5">{user.email}</p>
            </div>
          </div>

          <!-- 詳細データ -->
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div class="p-3 bg-slate-800/20 rounded-xl border border-slate-900">
              <span class="text-xs text-slate-500 block mb-1">🌍 国・地域</span>
              <span class="font-semibold text-slate-200">{user.location.country}</span>
            </div>
            <div class="p-3 bg-slate-800/20 rounded-xl border border-slate-900">
              <span class="text-xs text-slate-500 block mb-1">🎂 年齢</span>
              <span class="font-semibold text-slate-200">{user.dob.age} 歳</span>
            </div>
          </div>
        </div>
      ) : (
        <div class="text-center py-6 text-slate-500">
          読み込み中...
        </div>
      )}

      <!-- インタラクティブな React の島 (Island) -->
      <div class="mt-8 pt-6 border-t border-slate-800/60">
        <!-- カウンターをアイランドアーキテクチャ扱いでHTML送信 -> まとめてJSで送信 -->
        <Counter client:load />
      </div>

      <!-- 操作エリア -->
      <div class="mt-6 pt-6 border-t border-slate-800/60 flex flex-col gap-3">
        <button 
          onclick="window.location.reload()" 
          class="w-full py-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 active:scale-98 text-white font-semibold rounded-xl transition shadow-lg shadow-indigo-600/10 hover:shadow-indigo-500/20 cursor-pointer text-center text-sm"
        >
          ページを再読み込みする（再フェッチ）
        </button>
        
        <a href="/" class="text-center text-xs text-slate-500 hover:text-indigo-400 transition hover:underline mt-2">
          ← ダッシュボードに戻る
        </a>
      </div>

    </div>
  </main>
</Layout>
