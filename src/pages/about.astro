---
import Layout from '../layouts/Layout.astro';

// フロントマター（ビルド時に実行されるサーバーサイドJavaScript/TypeScript領域）
const pageTitle = "私について";
const identity = {
  firstName: "たろう",
  country: "日本",
  occupation: "Web開発者",
  hobbies: ["コーディング", "サウナ", "写真"],
};

const skills = ["HTML", "CSS", "JavaScript", "Astro", "Tailwind CSS"];

const happy = true;
const finished = false;
const goal = 3;
---

<Layout>
  <main class="min-h-screen bg-slate-950 text-slate-100 flex flex-col items-center justify-center p-6 font-sans">
    <div class="max-w-md w-full bg-slate-900 rounded-xl p-8 border border-slate-800">
      
      <!-- タイトルの表示 (プレーンなテキスト) -->
      <h1 class="text-2xl font-bold text-slate-100 mb-6">
        {pageTitle}
      </h1>

      <p class="text-slate-400 text-sm mb-4 leading-relaxed">
        Astro のフロントマターで定義した変数やオブジェクトを使って、このページを構築しています。
      </p>

      <!-- オブジェクトデータの表示 -->
      <ul class="space-y-2 mb-6 text-sm text-slate-300">
        <li>👤 名前: <span class="font-semibold text-slate-100">{identity.firstName}</span></li>
        <li>📍 国: {identity.country}</li>
        <li>💼 職業: {identity.occupation}</li>
        {identity.hobbies.length >= 2 && (
          <li>🎨 趣味: {identity.hobbies.join(', ')}</li>
        )}
      </ul>

      <!-- 配列のループ表示 (フラットなグレーのバッジ) -->
      <h2 class="text-base font-bold text-slate-200 mb-3">スキル</h2>
      <div class="flex flex-wrap gap-2 mb-6">
        {skills.map((skill) => (
          <span class="px-2.5 py-1 bg-slate-800 text-slate-300 border border-slate-700 rounded text-xs hover:bg-slate-600">
            {skill}
          </span>
        ))}
      </div>

      <!-- 条件分岐のテスト -->
      <div class="border-t border-slate-800 pt-4 text-xs text-slate-400 space-y-1">
        {happy && <p>😄 Astroの学習を楽しんでいます！</p>}
        {finished && <p>✅ このチュートリアルは完了しました！</p>}
        {goal === 3 ? <p>🎯 目標は3日以内の習得です。</p> : <p>🎯 目標はまだ決まっていません。</p>}
      </div>

      <div class="mt-8 text-center text-xs">
        <a href="/" class="before:content-['←'] before:ml-1 text-slate-400 hover:text-slate-200 hover:underline transition">
          トップページに戻る
        </a>
      </div>
    </div>
  </main>
</Layout>
