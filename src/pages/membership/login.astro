---
import Layout from '../../layouts/Layout.astro';
import LoginForm from '../../components/LoginForm.jsx';
---

<Layout>
  <main class="min-h-screen bg-slate-950 text-slate-100 flex flex-col items-center justify-center p-6 relative overflow-hidden font-sans">
    <!-- 装飾的な背景の光彩 -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <!-- React コンポーネントをクライアントロード -->
    <LoginForm client:load />

    <div class="mt-6 z-10">
      <a href="/" class="text-xs text-slate-500 hover:text-teal-400 transition hover:underline">
        ← トレーニングダッシュボードに戻る
      </a>
    </div>
  </main>
</Layout>
