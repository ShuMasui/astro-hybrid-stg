---
import Layout from '../../layouts/Layout.astro';
import LoginForm from '../../components/LoginForm.jsx';
---

<Layout>
  <main class="min-h-screen bg-slate-950 text-slate-100 flex flex-col items-center justify-center p-6 font-sans">
    
    <!-- React コンポーネントをクライアントロード -->
    <LoginForm client:load />

    <div class="mt-6">
      <a href="/" class="text-xs text-slate-500 hover:text-slate-300 transition hover:underline">
        ← トレーニングダッシュボードに戻る
      </a>
    </div>
  </main>
</Layout>
